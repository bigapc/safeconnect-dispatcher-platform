NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safeconnect
JWT_ACCESS_SECRET=replace_with_a_strong_secret
JWT_REFRESH_SECRET=replace_with_a_strong_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
SOCKET_URL=http://localhost:3001/dispatch
REDIS_URL=redis://localhost:6379
METRICS_ENABLED=true
LOG_RETENTION_DAYS=30
LOG_ARCHIVE_DIR=/tmp/safeconnect-log-archive
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SafeConnect <no-reply@safeconnect.local>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MAPBOX_ACCESS_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=safeconnect
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3004
